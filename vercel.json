{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": ""
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://flowcode.vercel.app https://flowcode-one.vercel.app https://*.vercel.app http://localhost:*"
        }
      ]
    }
  ]
}
